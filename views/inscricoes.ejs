<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Minhas Inscrições — SIMEC 2025</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <main class="container">
    <h1>Minhas Inscrições</h1>

    <% if (inscricoes.length === 0) { %>
      <div class="card-vazio">
        <p>Você ainda não tem inscrições.</p>
        <a href="/" class="btn btn-primary">Ver eventos disponíveis</a>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Evento</th>
              <th>Data</th>
              <th>Camiseta</th>
              <th>Áreas</th>
              <th>Inscrito em</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% inscricoes.forEach(i => { %>
              <tr id="inscricao-<%= i.id %>">
                <td><%= i.titulo %></td>
                <td><%= new Date(i.data_inicio).toLocaleDateString('pt-BR') %></td>
                <td><%= i.camiseta %></td>
                <td><%= i.areas || '—' %></td>
                <td><%= new Date(i.inscrito_em).toLocaleString('pt-BR') %></td>
                <td>
                  <button class="btn btn-danger btn-cancelar"
                          data-id="<%= i.id %>">
                    Cancelar
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <h2 style="margin-top:2rem">Inscrever-se em outro evento</h2>
    <% if (eventos.length) { %>
      <div class="card-grid">
        <% eventos.forEach(e => { %>
          <div class="card-evento">
            <h3><%= e.titulo %></h3>
            <p class="meta">📅 <%= new Date(e.data_inicio).toLocaleDateString('pt-BR') %></p>
            <p class="vagas">Vagas: <strong><%= e.vagas %></strong></p>
            <button class="btn btn-primary btn-inscrever"
                    data-evento="<%= e.id %>"
                    data-titulo="<%= e.titulo %>">
              Inscrever-se
            </button>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Campo oculto com CSRF token para fetch() -->
    <input type="hidden" id="csrf-token" value="<%= csrfToken %>">
    <p id="msg-acao" class="msg hidden"></p>
  </main>

  <!-- Modal de inscrição (reutilizado) -->
  <div id="modal-inscricao" class="modal hidden">
    <div class="modal-box">
      <h3 id="modal-titulo">Inscrição</h3>
      <form id="form-inscricao">
        <input type="hidden" name="evento_id" id="campo-evento-id">
        <label for="camiseta">Camiseta</label>
        <select name="camiseta" id="camiseta" required>
          <option value="">Selecione...</option>
          <option value="P">P</option>
          <option value="M">M</option>
          <option value="G">G</option>
          <option value="GG">GG</option>
        </select>
        <label for="areas">Áreas de interesse</label>
        <input type="text" name="areas" id="areas" placeholder="IA, Web, IoT...">
        <div class="modal-actions">
          <button type="submit" class="btn btn-primary">Confirmar</button>
          <button type="button" class="btn btn-outline" id="btn-fechar">Cancelar</button>
        </div>
        <p id="msg-inscricao" class="msg hidden"></p>
      </form>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/app.js"></script>
</body>
</html>
