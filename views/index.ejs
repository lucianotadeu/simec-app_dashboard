<%
  titulo = 'Início';
  const layout = `
  <section class="hero">
    <h1>Simpósio de Engenharia da Computação</h1>
    <p>15 e 16 de novembro de 2025 · Fortaleza, CE</p>
  </section>

  <section class="section-eventos">
    <h2>Eventos</h2>
    <div class="card-grid">
      ${eventos.map(e => `
        <div class="card-evento">
          <h3>${e.titulo}</h3>
          <p class="meta">📅 ${new Date(e.data_inicio).toLocaleDateString('pt-BR')}
            ${e.local_nome ? ' · 📍 ' + e.local_nome : ''}</p>
          <p>${e.descricao || ''}</p>
          <p class="vagas">Vagas: ${e.vagas}</p>
          ${usuarioId
            ? `<button class="btn btn-primary btn-inscrever" data-evento="${e.id}">Inscrever-se</button>`
            : `<a href="/login" class="btn btn-outline">Login para inscrever</a>`
          }
        </div>
      `).join('')}
    </div>
  </section>
  `;
%>
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SIMEC 2025</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <main class="container">

    <section class="hero">
      <h1>Simpósio de Engenharia<br>da Computação</h1>
      <p>15 e 16 de novembro de 2025 · Fortaleza, CE</p>
      <% if (!usuarioId) { %>
        <a href="/cadastro" class="btn btn-primary">Cadastrar-se</a>
        <a href="/login" class="btn btn-outline">Já tenho conta</a>
      <% } %>
    </section>

    <section>
      <h2>Eventos</h2>
      <div class="card-grid">
        <% eventos.forEach(e => { %>
          <div class="card-evento">
            <h3><%= e.titulo %></h3>
            <p class="meta">
              📅 <%= new Date(e.data_inicio).toLocaleDateString('pt-BR') %>
              <% if (e.local_nome) { %> · 📍 <%= e.local_nome %><% } %>
            </p>
            <% if (e.descricao) { %><p><%= e.descricao %></p><% } %>
            <p class="vagas">Vagas: <strong><%= e.vagas %></strong></p>
            <% if (usuarioId) { %>
              <button class="btn btn-primary btn-inscrever"
                      data-evento="<%= e.id %>"
                      data-titulo="<%= e.titulo %>">
                Inscrever-se
              </button>
            <% } else { %>
              <a href="/login" class="btn btn-outline">Login para inscrever</a>
            <% } %>
          </div>
        <% }) %>
      </div>
    </section>

  </main>

  <!-- Modal de inscrição -->
  <div id="modal-inscricao" class="modal hidden">
    <div class="modal-box">
      <h3 id="modal-titulo">Inscrição</h3>
      <form id="form-inscricao">
        <input type="hidden" name="_csrf" id="csrf-token" value="<%= csrfToken %>">
        <input type="hidden" name="evento_id" id="campo-evento-id">

        <label for="camiseta">Tamanho da camiseta</label>
        <select name="camiseta" id="camiseta" required>
          <option value="">Selecione...</option>
          <option value="P">P</option>
          <option value="M">M</option>
          <option value="G">G</option>
          <option value="GG">GG</option>
        </select>

        <label for="areas">Áreas de interesse (opcional)</label>
        <input type="text" name="areas" id="areas"
               placeholder="ex.: IA, Web, IoT">

        <div class="modal-actions">
          <button type="submit" class="btn btn-primary">Confirmar inscrição</button>
          <button type="button" class="btn btn-outline" id="btn-fechar">Cancelar</button>
        </div>
        <p id="msg-inscricao" class="msg hidden"></p>
      </form>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/app.js"></script>
</body>
</html>
