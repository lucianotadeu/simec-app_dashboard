# ─────────────────────────────────────────────────────────────
#  SIMEC — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA versione o arquivo .env no Git!
# ─────────────────────────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados MySQL
# Em desenvolvimento: localhost / XAMPP / Docker
# Em produção: string fornecida pelo Railway, PlanetScale, etc.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=simec_db
DB_USER=root
DB_PASS=

# Sessão — gere com: node -e "require('crypto').randomBytes(64).toString('hex')|0"
SESSION_SECRET=troque_por_64_chars_aleatorios_aqui

# Ambiente (development | production)
# Em produção, defina NODE_ENV=production no painel do Render
